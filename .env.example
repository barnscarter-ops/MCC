# MCC Dashboard — Environment Configuration
# Copy this file to .env and fill in your values.

# Server
PORT=3000

# SEO Agents App (mav-bridge process — HTTP server on port 8790)
# This replaces the deprecated MAV_REPO_BRIDGE_URL
SEO_APP_URL=http://127.0.0.1:8790

# OpenAI / LiteLLM proxy
OPENAI_API_KEY=
OPENAI_BASE_URL=http://192.168.1.12:4000

# NVIDIA NIM
NVIDIA_NIM_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# RAG server (LAN)
MAV_RAG_URL=http://192.168.1.12:8181

# Prometheus
PROMETHEUS_URL=http://192.168.1.12:9090

# Local llama.cpp server
LLAMA_SERVER_URL=http://127.0.0.1:8080
LOCAL_MODEL=qwen3-14b

# Pi RPC
PI_EXECUTABLE=pi
PI_MODEL=qwen3-14b

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Workspace
MAV_CONSOLE_WORKSPACE=
MAV_CONSOLE_DATA_DIR=
MAV_MEMORY_PATH=
MAV_SKILLS_PATH=
MAV_EXTRA_ROOTS=

# HCP (Grizzly-HCP repo for estimate pipeline)
HCP_PROJECT_DIR=

# Brave Search (optional)
BRAVE_SEARCH_API_KEY=

# OpenAI Realtime (must be a real OpenAI key, not LiteLLM proxy key)
OPENAI_REALTIME_KEY=
